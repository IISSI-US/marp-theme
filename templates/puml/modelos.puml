@startuml employees-mc
!include ../../puml/final.iuml

class Empleado {
  nombre
  salario
  fechaInicial
  fechaFinal
  comision
}

class Departamento {
  nombreDep
  localidad
}

Empleado "*" --> "0..1" Departamento : trabajaEn
Empleado "0..1" --> "*" Empleado : esJefeDe

note bottom of Departamento
  La combinación
  (nombreDep, localidad)
  no se puede repetir
end note

note top of Empleado
  La fecha incial no puede ser 
  superiror que la fecha final. 
  El nombre del empleado es único.
  La comisión entre 0 y 1.
end note
@enduml

@startuml ejemplo-mdd
!include ../../puml/final.iuml

class Laboratorio {
  cif
  nombre
  direccion
}

class Catalogo {
  fecha
}

class Almacen {
  nombre
  direccion
}

class LineaCatalogo {
  precioMenorXcien
  precioMasDeCien
}

class Producto {
  codigo
  nombre
  descripcion
}

Laboratorio *-- "0..*" Catalogo: publica
Laboratorio "?" -- "0..*" Almacen: > almacenaProductosEn
Catalogo *-- "1..*" LineaCatalogo: contiene
LineaCatalogo "*" -- "1" Producto : referencia
@enduml



